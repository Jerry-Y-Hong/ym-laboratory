# RDA (농촌진흥청 농식품올바로) OpenAPI Configuration
RDA_API_KEY=YOUR_RDA_OPENAPI_KEY_HERE
RDA_API_BASE_URL=http://api.nongsaro.go.kr/service
RDA_API_TIMEOUT=10
RDA_API_MAX_RETRIES=3

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
