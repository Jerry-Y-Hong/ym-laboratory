# ==============================================================================
# ACPP ENVIRONMENT VARIABLES (ADF v3.1)
# Copy to .env and fill in production values. Never commit .env to VCS.
# ==============================================================================

# ── System ────────────────────────────────────────────────────────────────────
ACPP_ENV=development
ACPP_LOG_LEVEL=DEBUG
ACPP_TENANT_ID=tenant-default

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://acpp_admin:changeme@localhost:5432/acpp_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── AI Engine Credentials ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE-ME
AZURE_OPENAI_API_KEY=

# ── Security (AAOS / AEGS) ───────────────────────────────────────────────────
AAOS_SECRET_KEY=aaos-secret-key-hmac-sha256-replace-me
AEGS_GOVERNANCE_GATE_KEY=aegs-governance-gate-secret-replace-me

# ── External CMS (Publishing Agent) ──────────────────────────────────────────
WORDPRESS_API_ENDPOINT=
WORDPRESS_AUTH_TOKEN=
GHOST_CMS_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
