    },
    "기를 소통시키고 춘곤증을 해소하는 봄철 나물 요리입니다.": {
      "ko": "기를 소통시키고 춘곤증을 해소하는 봄철 나물 요리입니다.",
      "en": "Spring herb dish that circulates qi and relieves spring fatigue.",
      "ja": "気を通りやすくし、春の疲労を解消する春のナムル料理です。",
      "ar": "طبق أعشاب ربيعية ينشط طاقة تشي ويخفف من تعب الربيع."
    },
    "습기를 물리치고 비위에 기를 소통시키는 봄철 쑥부침개입니다.": {
      "ko": "습기를 물리치고 비위에 기를 소통시키는 봄철 쑥부침개입니다.",
      "en": "Spring mugwort pancake that dispels dampness and harmonizes stomach.",
      "ja": "湿気を払い、胃腸の気を巡らせる春のヨモギチヂミです。",
      "ar": "فطيرة الشيح الربيعية التي تطرد الرطوبة وتنسق المعدة."
    },
    "춘설의 갑작스러운 한기에 몸을 보하는 천궁과 당귀의 따뜻한 국물입니다.": {
      "ko": "춘설의 갑작스러운 한기에 몸을 보하는 천궁과 당귀의 따뜻한 국물입니다.",
      "en": "Warm cnidium & angelica soup protecting the body against sudden cold of spring snow.",
      "ja": "春の雪の突然の寒さから体を守る、川芎と当帰の温かいスープです。",
      "ar": "حساء السنيديوم والأنجليكا الدافئ الذي يحمي الجسم من البرد المفاجئ لثلوج الربيع."
    },
    "황사 바람 미세먼지를 해독하고 호흡기를 보호하는 방풍나물입니다.": {
      "ko": "황사 바람 미세먼지를 해독하고 호흡기를 보호하는 방풍나물입니다.",
      "en": "Ledebouriella herb that detoxifies yellow dust micro-particles and protects lungs.",
      "ja": "黄砂や微小粒子の毒を消し、呼吸器を保護するボウフウナ料理です。",
      "ar": "عشبة ليديبوريلا التي تطهر من جزيئات الغبار الأصفر الدقيقة وتحمي الرئتين."
    },
    "꽃샘추위에 상한 위장을 데우고 기운을 보강하는 닭고기 요리입니다.": {
      "ko": "꽃샘추위에 상한 위장을 데우고 기운을 보강하는 닭고기 요리입니다.",
      "en": "Chicken dish that warms the stomach damaged by cold snaps and boosts energy.",
      "ja": "花冷えで冷えた胃腸を温め、元気を補強하는鶏肉料理です。",
      "ar": "طبق دجاج يدفئ المعدة المتضررة من موجات البرد ويعزز الطاقة."
    },
    "갑자기 찾아온 더위에 몸의 기를 보호하는 나물 생채입니다.": {
      "ko": "갑자기 찾아온 더위에 몸의 기를 보호하는 나물 생채입니다.",
      "en": "Seasoned fresh herbs that protect body qi from sudden early heat.",
      "ja": "急に訪れた暑さから体の気を守るナムル生野菜和えです。",
      "ar": "الأعشاب الطازجة المتبلة التي تحمي طاقة تشي في الجسم من الحرارة المبكرة المفاجئة."
    },
    "무더운 날씨에 체내 진액을 보충하고 열을 내려주는 메밀밀쌈입니다.": {
      "ko": "무더운 날씨에 체내 진액을 보충하고 열을 내려주는 메밀밀쌈입니다.",
      "en": "Buckwheat crepe that replenishes body fluids and lowers heat in hot weather.",
      "ja": "暑い天気に体内の津液を補い、熱を下げるそば粉クレープ巻きです。",
      "ar": "كريب الحنطة السوداء الذي يعوض سوائل الجسم ويخفض الحرارة في الطقس الحار."
    },
    "비 오는 날 몸에 머물기 쉬운 습기를 제거하고 기혈을 활성화하는 파전입니다.": {
      "ko": "비 오는 날 몸에 머물기 쉬운 습기를 제거하고 기혈을 활성화하는 파전입니다.",
      "en": "Scallion pancake that removes dampness and activates blood flow on rainy days.",
      "ja": "雨の日に体に溜まりやすい湿気を取り除き、気血を活性化するチヂミです。",
      "ar": "فطيرة الكرنب الأخضر التي تزيل الرطوبة وتنشط تدفق الدم في الأيام الممطرة."
    },
    "더위 속 이례적인 찬 바람에 몸의 기를 보호하는 시원한 미역국입니다.": {
      "ko": "더위 속 이례적인 찬 바람에 몸의 기를 보호하는 시원한 미역국입니다.",
      "en": "Cooling seaweed soup that protects body qi from unusual summer cold winds.",
      "ja": "暑さの中の異例の冷たい風から体の気を保護する、さっぱりしたわかめスープです。",
      "ar": "حساء الأعشاب البحرية المبرد الذي يحمي طاقة تشي في الجسم من رياح الصيف الباردة غير العادية."
    },
    "고온 건조한 바람에 메마른 기관지를 촉촉하게 적셔주는 은이버섯 배숙입니다.": {
      "ko": "고온 건조한 바람에 메마른 기관지를 촉촉하게 적셔주는 은이버섯 배숙입니다.",
      "en": "White wood ear & pear dish that moistens the respiratory tract in high dry winds.",
      "ja": "高温で乾燥した風に乾いた気管支を潤す白キクラゲと梨の温菜です。",
      "ar": "طبق أذن الخشب الأبيض والكمثرى الذي يرطب الجهاز التنفسي في الرياح الجافة الشديدة."
    },
    "여름 냉방병과 체온 저하를 막아주고 원기를 돋우는 한방 삼계탕입니다.": {
      "ko": "여름 냉방병과 체온 저하를 막아주고 원기를 돋우는 한방 삼계탕입니다.",
      "en": "Korean chicken soup that prevents air-conditioning sickness and boosts vitality.",
      "ja": "夏のクーラー病と体温低下を防ぎ、元気を引き出す漢方参鶏湯です。",
      "ar": "حساء الدجاج الكوري الذي يمنع المرض الناتج عن التكييف ويعزز الحيوية."
    },
    "폭염 속에 머리의 열을 내리고 피로를 풀어주는 시원한 메밀국수입니다.": {
      "ko": "폭염 속에 머리의 열을 내리고 피로를 풀어주는 시원한 메밀국수입니다.",
      "en": "Cooling buckwheat noodles that lower head heat and relieve fatigue in heat waves.",
      "ja": "猛暑の中で頭の熱を下げ、疲労を回復させる冷たいそばです。",
      "ar": "نودلز الحنطة السوداء المبردة التي تخفض حرارة الرأس وتخفف التعب في موجات الحر."
    },
    "건조한 가을날 폐를 윤택하게 하고 신장을 보하는 든든한 산약 경단입니다.": {
      "ko": "건조한 가을날 폐를 윤택하게 하고 신장을 보하는 든든한 산약 경단입니다.",
      "en": "Reliable mountain yam rice balls that moisten lungs and benefit kidneys in dry autumn.",
      "ja": "乾燥した秋の日に肺を潤し、腎臓を補う頼もしい山薬団子です。",
      "ar": "كرات أرز يام الجبلية التي ترطب الرئتين وتفيد الكلى في الخريف الجاف."
    },
    "비 오는 날 기운이 가라앉는 것을 방지하고 기혈 순환을 유도하는 백합 연근전입니다.": {
      "ko": "비 오는 날 기운이 가라앉는 것을 방지하고 기혈 순환을 유도하는 백합 연근전입니다.",
      "en": "Lily bulb & lotus root pancake that prevents sinking energy and prompts circulation.",
      "ja": "雨の日に気が沈むのを防ぎ、気血の循環を促す百合根とレンコンのチヂミです。",
      "ar": "فطيرة بصلة الزنبق وجذر اللوتس التي تمنع هبوط الطاقة وتحفز الدورة الدموية."
    },
    "초겨울 기습적인 눈에 폐와 기관지를 따뜻하게 보하는 도라지 갈비탕입니다.": {
      "ko": "초겨울 기습적인 눈에 폐와 기관지를 따뜻하게 보하는 도라지 갈비탕입니다.",
      "en": "Beef rib soup with liriope that warms lungs and airways in sudden early winter snow.",
      "ja": "初冬の急な雪に肺と気管支を温め保護するカルビタンです。",
      "ar": "حساء أضلاع البقر مع ليريوب الذي يدفئ الرئتين والممرات الهوائية في ثلوج الشتاء المبكرة المفاجئة."
    },
    "건조한 가을바람으로부터 인후와 기관지를 보호하고 기침을 진정시키는 도라지탕입니다.": {
      "ko": "건조한 가을바람으로부터 인후와 기관지를 보호하고 기침을 진정시키는 도라지탕입니다.",
      "en": "Balloon flower root tea that protects throat and bronchus from dry autumn winds.",
      "ja": "乾燥した秋の風から喉と気管支を保護し、咳を鎮める桔梗湯です。",
      "ar": "شاي جذر زهرة البالون الذي يحمي الحلق والشعب الهوائية من رياح الخريف الجافة."
    },
    "쌀쌀한 바람에 상하기 쉬운 위장을 따뜻하게 보하고 기력을 돕는 복령 만두입니다.": {
      "ko": "쌀쌀한 바람에 상하기 쉬운 위장을 따뜻하게 보하고 기력을 돕는 복령 만두입니다.",
      "en": "Poria cocos dumplings that warm the stomach easily damaged by chilly winds and boost qi.",
      "ja": "肌寒い風に傷つきやすい胃腸を温め、気力を助ける茯苓餃子です。",
      "ar": "زلابية بوريا كوكوس التي تدفئ المعدة التي تتلف بسهولة بسبب الرياح الباردة وتعزز طاقة تشي."
    },
    "늦더위로 인한 갈증을 해소하고 진액을 생성하는 다섯 가지 맛의 오미자 화채입니다.": {
      "ko": "늦더위로 인한 갈증을 해소하고 진액을 생성하는 다섯 가지 맛의 오미자 화채입니다.",
      "en": "Five-flavor omija punch that relieves thirst and generates fluids in late autumn heat.",
      "ja": "残暑による喉の渇きを癒し、津液を生成する五味子花菜です。",
      "ar": "شراب فواكه أوميجا ذو النكهات الخمس الذي يخفف العطش ويعوض سوائل الجسم في حرارة الخريف المتأخرة."
    },
    "차가운 겨울날 혈액 순환을 돕고 몸을 속부터 따뜻하게 하는 구기자 대추차입니다.": {
      "ko": "차가운 겨울날 혈액 순환을 돕고 몸을 속부터 따뜻하게 하는 구기자 대추차입니다.",
      "en": "Goji berry & jujube tea that aids blood circulation and warms body on cold winter days.",
      "ja": "冷たい冬の日に血液循環を助け、体を芯から温めるクコの実ナツメ茶です。",
      "ar": "شاي توت الغوجي والعناب الذي يساعد على الدورة الدموية ويدفئ الجسم في أيام الشتاء الباردة."
    },
    "겨울비에 몸이 눅눅하고 시릴 때 비위를 보호하고 기운을 돋우는 버섯전입니다.": {
      "ko": "겨울비에 몸이 눅눅하고 시릴 때 비위를 보호하고 기운을 돋우는 버섯전입니다.",
      "en": "Mushroom pancake that protects the stomach and boosts energy when body is damp and cold from winter rain.",
      "ja": "冬の雨で体が冷えて湿っぽい時に胃腸を保護し、元気を出すキノコチヂミです。",
      "ar": "فطيرة الفطر التي تحمي المعدة وتعزز الطاقة عندما يكون الجسم رطباً وبارداً بسبب مطر الشتاء."
    },
    "함박눈이 내릴 때 몸의 열을 지키고 피를 맑게 해주는 겨울 별미 매생이 굴국입니다.": {
      "ko": "함박눈이 내릴 때 몸의 열을 지키고 피를 맑게 해주는 겨울 별미 매생이 굴국입니다.",
      "en": "Seaweed & oyster soup that protects body heat and purifies blood during heavy snow.",
      "ja": "大雪の日に体の熱を守り、血液をサラサラにするカプサアオノリと牡蠣のスープです。",
      "ar": "حساء الأعشاب البحرية والمحار الذي يحمي حرارة الجسم وينقي الدم أثناء الثلوج الكثيفة."
    },
    "겨울 황사와 건조한 공기로부터 목과 폐를 보호하는 도라지 만두입니다.": {
      "ko": "겨울 황사와 건조한 공기로부터 목과 폐를 보호하는 도라지 만두입니다.",
      "en": "Liriope spicata dumplings that protect throat and lungs from winter yellow dust and dry air.",
      "ja": "冬の黄砂と乾燥した空気から喉と肺を保護する桔梗餃子です。",
      "ar": "زلابية ليريوب سبيكاتا التي تحمي الحلق والرئتين من الغبار الأصفر الشتوي والهواء الجاف."
    },
    "한파 속에 관절과 뼈를 튼튼하게 하고 양기를 보충하는 뜨거운 도가니탕입니다.": {
      "ko": "한파 속에 관절과 뼈를 튼튼하게 하고 양기를 보충하는 뜨거운 도가니탕입니다.",
      "en": "Ox knee bone soup that strengthens joints/bones and replenishes yang energy in cold waves.",
      "ja": "寒波の中で関節と骨を丈夫にし、陽気を補う熱いトガニタンです。",
      "ar": "حساء عظام ركبة الثور الذي يقوي المفاصل/العظام ويعوض طاقة اليانغ في موجات البرد."
    },
    "겨울철 실내 난방 열기로 답답해진 가슴을 시원하게 풀어주는 동태탕입니다.": {
      "ko": "겨울철 실내 난방 열기로 답답해진 가슴을 시원하게 풀어주는 동태탕입니다.",
      "en": "Pollack soup that refreshes the chest stuffy from indoor dry winter heating.",
      "ja": "冬の室内暖房の熱気で息苦しくなった胸をすっきりとほぐすスケトウダラ鍋です。",
      "ar": "حساء سمك البولاك الذي ينعش الصدر الضيق بسبب التدفئة الشتوية الجافة داخل المنزل."
    },
