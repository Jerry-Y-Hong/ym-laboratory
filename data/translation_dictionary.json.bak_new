    "전 체질 — 기본 보양 곡물": {
      "ko": "전 체질 — 기본 보양 곡물",
      "en": "All Constitutions — Essential Tonic Grain",
      "ja": "全体質 — 基本滋養穀物",
      "ar": "جميع الدساتير - حبوب مقوية أساسية"
    },
    "적미·흑미 블렌드 잡곡세트": {
      "ko": "적미·흑미 블렌드 잡곡세트",
      "en": "Red & Black Mixed Grain Set",
      "ja": "赤米・黒米ブレンド雑穀セット",
      "ar": "مجموعة الحبوب المختلطة الحمراء والسوداء"
    },
    "항산화 안토시아닌이 풍부한 토종 적미와 흑미 황금 비율 혼합. 혈중 순환 개선과 진액 보충에 도움.": {
      "ko": "항산화 안토시아닌이 풍부한 토종 적미와 흑미 황금 비율 혼합. 혈중 순환 개선과 진액 보충에 도움.",
      "en": "A golden ratio blend of native red and black rice rich in antioxidant anthocyanins. Helps improve blood circulation and replenish vital body fluids.",
      "ja": "抗酸化作用のあるアントシアニンが豊富な国産赤米と黒米の黄金比ブレンド。血行促進と水分補給に貢献します。",
      "ar": "مزيج بالنسبة الذهبية من الأرز الأحمر والأسود الأصلي الغني بأنثوسيانين المضاد للأكسدة. يساعد على تحسين الدورة الدموية وتجديد سوائل الجسم الحيوية."
    },
    "백미와 잡곡을 7:3의 비율로 혼합하여 밥을 지으면 찰기와 영양이 조화를 이룹니다.": {
      "ko": "백미와 잡곡을 7:3의 비율로 혼합하여 밥을 지으면 찰기와 영양이 조화를 이룹니다.",
      "en": "Blend white rice and mixed grains in a 7:3 ratio for a perfect balance of stickiness and nutrition.",
      "ja": "白米と雑穀を7:3の割合で混ぜて炊くと、粘りと栄養のバランスが良くなります。",
      "ar": "امزج الأرز الأبيض والحبوب المختلطة بنسبة 7:3 للحصول على توازن مثالي بين اللزوجة والتغذية."
    },
    "소화력이 극도로 떨어진 소음인은 잡곡 비율을 10% 이하로 줄여 드시는 것이 좋습니다.": {
      "ko": "소화력이 극도로 떨어진 소음인은 잡곡 비율을 10% 이하로 줄여 드시는 것이 좋습니다.",
      "en": "Individuals of Soeumin constitution with very weak digestion are advised to reduce the ratio of mixed grains to 10% or less.",
      "ja": "消化力が著しく低下している少陰人は、雑穀の割合を10%以下に減らしてお召し上がりになることをお勧めします。",
      "ar": "يُنصح الأفراد من دستور سومين الذين يعانون من هضم ضعيف للغاية بتقليل نسبة الحبوب المختلطة إلى 10% أو أقل."
    },
    "토종 잡곡": {
      "ko": "토종 잡곡",
      "en": "Native Mixed Grains",
      "ja": "在来種雑穀",
      "ar": "حبوب مختلطة أصلية"
    },
    "3kg / 1세트": {
      "ko": "3kg / 1세트",
      "en": "3kg / 1 set",
      "ja": "3kg / 1セット",
      "ar": "3 كجم / مجموعة واحدة"
    },
    "전통 3년 숙성 된장 (옹기 항아리)": {
      "ko": "전통 3년 숙성 된장 (옹기 항아리)",
      "en": "Traditional 3-Year Aged Doenjang",
      "ja": "伝統3年熟成味噌 (オンギ壺)",
      "ar": "معجون فول الصويا (دوينجانغ) المعتق لثلاث سنوات"
    },
    "100% 국산 대두로 메주를 빚어 전통 옹기에 3년 자연 발효한 된장. 깊은 감칠맛과 풍부한 프로바이오틱스.": {
      "ko": "100% 국산 대두로 메주를 빚어 전통 옹기에 3년 자연 발효한 된장. 깊은 감칠맛과 풍부한 프로바이오틱스.",
      "en": "Doenjang naturally fermented for 3 years in traditional earthenware jars (onggi) using 100% Korean soybeans. Features deep savory umami and rich probiotics.",
      "ja": "100%韓国産大豆でメジュ（味噌玉）を作り、伝統のオンギ壺で3年間自然発酵させた味噌。深い旨味と豊富なプロバイオティクスが特徴です。",
      "ar": "دوينجانغ مخمر بشكل طبيعي لمدة 3 سنوات في أواني فخارية تقليدية (أونجي) باستخدام فول الصويا الكوري بنسبة 100%. يتميز بنكهة أومامي غميقة وبروبيوتيك غني."
    },
    "찌개나 국을 끓일 때 불을 끄기 5분 전에 된장을 풀어 끓여야 유익균 손실을 최소화합니다.": {
      "ko": "찌개나 국을 끓일 때 불을 끄기 5분 전에 된장을 풀어 끓여야 유익균 손실을 최소화합니다.",
      "en": "When cooking stews or soups, dissolve the doenjang 5 minutes before turning off the heat to minimize the loss of beneficial bacteria.",
      "ja": "チゲやスープを作る際、火を止める5分前に味噌を溶き入れると、有益な菌の損失を最小限に抑えられます。",
      "ar": "عند طهي الحساء أو المرق، ذوّب الدوينجانغ قبل 5 دقائق من إطفاء الحرارة لتقليل فقدان البكتيريا النافعة."
    },
    "염도가 있으므로 고혈압이나 신장 질환자는 과다 섭취에 주의하고 조리 시 양을 조절하십시오.": {
      "ko": "염도가 있으므로 고혈압이나 신장 질환자는 과다 섭취에 주의하고 조리 시 양을 조절하십시오.",
      "en": "Due to sodium content, hypertensive or kidney disease patients should consume in moderation and adjust amounts during cooking.",
      "ja": "塩分があるため、高血圧や腎臓疾患のある方は過剰摂取に注意し、調理時の量を調整してください。",
      "ar": "بسبب محتوى الصوديوم، يجب على مرضى ضغط الدم المرتفع أو الكلى الاستهلاك باعتدال وتعديل الكميات أثناء الطهي."
    },
    "3년 자연 발효": {
      "ko": "3년 자연 발효",
      "en": "3-Year Natural Aging",
      "ja": "3年自然発酵",
      "ar": "تخمير طبيعي لثلاث سنوات"
    },
    "500g / 1옹기": {
      "ko": "500g / 1옹기",
      "en": "500g / 1 earthenware pot",
      "ja": "500g / 1壺",
      "ar": "500 جم / وعاء فخاري واحد"
    },
    "청양 수제 고추장 (전통 방식)": {
      "ko": "청양 수제 고추장 (전통 방식)",
      "en": "Cheongyang Hand-Made Gochujang",
      "ja": "青陽手作りコチュジャン (伝統製法)",
      "ar": "معجون الفلفل الحار (غوتشوجانغ) المصنوع يدويًا"
    },
    "청양 고춧가루와 찹쌀 발효물로 만든 수제 고추장. 대사 활성화와 소화 촉진에 도움.": {
      "ko": "청양 고춧가루와 찹쌀 발효물로 만든 수제 고추장. 대사 활성화와 소화 촉진에 도움.",
      "en": "Handcrafted gochujang made with Cheongyang chili powder and fermented glutinous rice. Helps stimulate metabolism and digestion.",
      "ja": "青陽（チョンヤン）唐辛子粉ともち米発酵物で作られた手作りコチュジャン。新陳代謝の活性化と消化促進をサポートします。",
      "ar": "غوتشوجانغ مصنوع يدويًا من مسحوق فلفل تشيونغيانغ والأرز الدبق المخمر. يساعد على تحفيز التمثيل الغذائي والهضم."
    },
    "무침 요리나 찌개 조림의 양념 베이스로 적절히 환산하여 조리에 사용하십시오.": {
      "ko": "무침 요리나 찌개 조림의 양념 베이스로 적절히 환산하여 조리에 사용하십시오.",
      "en": "Use as a seasoning base for seasoned dishes, stews, or braises, measuring out appropriate amounts.",
      "ja": "和え物やチゲ、煮物の調味ベースとして、調理時に適量を使用してください。",
      "ar": "يُستخدم كقاعدة توابل للأطباق المتبلة أو الحساء أو اليخنات، مع قياس الكميات المناسبة."
    },
    "위염, 위궤양이 있거나 소양인 체질 중 위열이 높은 분은 과다 섭취를 삼가십시오.": {
      "ko": "위염, 위궤양이 있거나 소양인 체질 중 위열이 높은 분은 과다 섭취를 삼가십시오.",
      "en": "Individuals with gastritis, stomach ulcers, or high stomach heat (Soyangmin) should avoid excessive intake.",
      "ja": "胃炎、胃潰瘍のある方や、少陽人体質で胃熱の高い方は、過剰な摂取をお控えください。",
      "ar": "يجب على الأشخاص الذين يعانون من التهاب المعدة أو قرحة المعدة أو حرارة المعدة المرتفعة (سويانغمين) تجنب الاستهلاك المفرط."
    },
    "수제 전통": {
      "ko": "수제 전통",
      "en": "Handmade Traditional",
      "ja": "手作り伝統",
      "ar": "تقليدي مصنوع يدويًا"
    },
    "500g / 1단지": {
      "ko": "500g / 1단지",
      "en": "500g / 1 jar",
      "ja": "500g / 1単磁",
      "ar": "500 جم / جرة واحدة"
    },
    "전통 조선 간장 (2년 저온 숙성)": {
      "ko": "전통 조선 간장 (2년 저온 숙성)",
      "en": "Traditional Joseon Soy Sauce",
      "ja": "伝統朝鮮醤油 (2年低温熟成)",
      "ar": "صلصة صويا جوسون التقليدية"
    },
    "콩 단일 원료로 2년 이상 자연 숙성. 나트륨 낮고 아미노산 풍부 — 혈압 조절과 신장 기능 보호.": {
      "ko": "콩 단일 원료로 2년 이상 자연 숙성. 나트륨 낮고 아미노산 풍부 — 혈압 조절과 신장 기능 보호.",
      "en": "Naturally aged for over 2 years using soybeans as the single ingredient. Low in sodium and rich in amino acids — helps regulate blood pressure and protects kidney function.",
      "ja": "大豆のみを原料とし、2年以上自然熟成させた醤油。塩分が控えめでアミノ酸が豊富 — 血圧調整と腎臓機能の保護に貢献します。",
      "ar": "معتقة بشكل طبيعي لأكثر من عامين باستخدام فول الصويا كمكون وحيد. منخفضة الصوديوم وغنية بالأحماض الأمينية - تساعد على تنظيم ضغط الدم وتحمي وظائف الكلى."
    },
    "국물 요리의 간을 맞추거나 나물 무침의 밑간용 조미료로 극소량 사용합니다.": {
      "ko": "국물 요리의 간을 맞추거나 나물 무침의 밑간용 조미료로 극소량 사용합니다.",
      "en": "Use in very small amounts as a seasoning for soup seasoning or as a light marinade for vegetable side dishes.",
      "ja": "汁物料理の塩加減の調整や、ナムル和えの下味用としてごく少量を使用します。",
      "ar": "تُستخدم بكميات صغيرة جدًا كتوابل لحساء المرق أو كعصير خفيف للأطباق الجانبية للخضروات."
    },
    "나트륨 함량이 높으므로 1회 조리 시 15ml(1큰술) 이내 사용을 권장합니다.": {
      "ko": "나트륨 함량이 높으므로 1회 조리 시 15ml(1큰술) 이내 사용을 권장합니다.",
      "en": "High in sodium. Recommended limit is under 15ml (1 tablespoon) per cooking session.",
      "ja": "ナトリウム分が多いため、1回の調理時に15ml（大さじ1杯）以内の使用をお勧めします。",
      "ar": "مرتفع الصوديوم. الحد الموصى به أقل من 15 مل (ملعقة كبيرة واحدة) لكل طبخة."
    },
    "2년 저온 숙성": {
      "ko": "2년 저온 숙성",
      "en": "2-Year Cold Aging",
      "ja": "2年低温熟成",
      "ar": "تعتيق بارد لعامين"
    },
    "강원 야생 황기 (黃芪)": {
      "ko": "강원 야생 황기 (黃芪)",
      "en": "Premium Astragalus Root (Hwanggi)",
      "ja": "江原道野生黄花黄耆",
      "ar": "جذر القتاد البري الممتاز (هوانغجي)"
    },
    "해발 600m 이상 청정 지역 야생 황기. 기력 보충·면역 강화의 으뜸 약재. 삼계탕, 보양탕의 핵심 본초.": {
      "ko": "해발 600m 이상 청정 지역 야생 황기. 기력 보충·면역 강화의 으뜸 약재. 삼계탕, 보양탕의 핵심 본초.",
      "en": "Wild astragalus harvested from clean regions above 600m altitude. The premier herb for restoring energy and strengthening immunity; an essential botanical for samgyetang and nourishing tonics.",
      "ja": "標高600m以上の清浄地域で採取された野生の黄耆（オウギ）。気力補給・免疫力強化の代表的な生薬。参鶏湯（サムゲタン）や健康保養湯に欠かせない素材です。",
      "ar": "قتاد بري يتم حصاده من مناطق نظيفة على ارتفاع يزيد عن 600 متر. العشبة الأولى لاستعادة الطاقة وتقوية المناعة؛ نبات أساسي لسامجيتانغ والمقويات المغذية."
    },
    "황기 20g에 물 1L를 붓고 약불에서 40분간 달여 차로 마시거나 삼계탕 조리 시 넣어 우려냅니다.": {
      "ko": "황기 20g에 물 1L를 붓고 약불에서 40분간 달여 차로 마시거나 삼계탕 조리 시 넣어 우려냅니다.",
      "en": "Boil 20g of astragalus in 1L of water over low heat for 40 minutes to drink as a tea, or add to soup when cooking samgyetang.",
      "ja": "水1Lに黄耆20gを入れ、弱火で40分間煮出して茶として飲むか、参鶏湯の調理時に入れて出汁を取ります。",
      "ar": "يُغلى 20 جم من القتاد في لتر من الماء على نار خفيفة لمدة 40 دقيقة لشربه كشاي، أو يُضاف إلى الحساء عند طهي السامجيتانغ."
    },
    "몸에 열이 많고 얼굴이 붉은 소양인 체질이나 급성 염증성 질환자는 피하시는 것이 좋습니다.": {
      "ko": "몸에 열이 많고 얼굴이 붉은 소양인 체질이나 급성 염증성 질환자는 피하시는 것이 좋습니다.",
      "en": "Those with high body heat or flushed face (Soyangmin) and those with acute inflammatory conditions should avoid it.",
      "ja": "体に熱が多く顔が赤くなりやすい少陽人や、急性炎症性疾患のある方はお控えになることをお勧めします。",
      "ar": "يجب على الأشخاص الذين يعانون من حرارة الجسم المرتفعة أو احمرار الوجه (سويانغمين) والذين يعانون من حالات التهابية حادة تجنبه."
    },
    "야생 채취": {
      "ko": "야생 채취",
      "en": "Wild Harvested",
      "ja": "野生採取",
      "ar": "محصود برياً"
    },
    "100g / 건초": {
      "ko": "100g / 건초",
      "en": "100g / dried herb",
      "ja": "100g / 乾草",
      "ar": "100 جم / عشب مجفف"
    },
    "지리산 구기자 (枸杞子)": {
      "ko": "지리산 구기자 (枸杞子)",
      "en": "Jirisan Premium Goji Berry",
      "ja": "智異山クコの実 (枸杞子)",
      "ar": "توت غوجي جيريسان الفاخر"
    },
    "지리산 청정 계곡 주변 토종 구기자. 간신 보양, 눈 기능 개선, 노화 방지에 탁월.": {
      "ko": "지리산 청정 계곡 주변 토종 구기자. 간신 보양, 눈 기능 개선, 노화 방지에 탁월.",
      "en": "Native goji berries harvested near the pristine valleys of Jirisan. Outstanding for nourishing liver and kidneys, improving eye health, and anti-aging.",
      "ja": "智異山（チリサン）の清浄な渓谷周辺で採取された在来種クコの実。肝臓と腎臓を補養し、目の機能改善、アンチエイジングに優れています。",
      "ar": "توت غوجي أصلي يتم حصاده بالقرب من وديان جيريسان النقية. ممتاز لتغذية الكبد والكلى، وتحسين صحة العين، ومكافحة الشيخوخة."
    },
    "물 1L에 가볍게 볶은 구기자 15g을 넣고 30분간 끓여 식후 차로 음용하십시오.": {
      "ko": "물 1L에 가볍게 볶은 구기자 15g을 넣고 30분간 끓여 식후 차로 음용하십시오.",
      "en": "Add 15g of lightly roasted goji berries to 1L of water, boil for 30 minutes, and drink as a tea after meals.",
      "ja": "水1Lに軽く炒ったクコの実15gを入れ、30分間沸騰させて食後にお茶としてお召し上がりください。",
      "ar": "أضف 15 جم من توت غوجي المحمص خفيفًا إلى لتر من الماء، واغله لمدة 30 دقيقة، واشربه كشاي بعد الوجبات."
    },
    "대변이 묽거나 설사가 잦은 분은 구기자의 서늘한 성질로 인해 설사가 심해질 수 있습니다.": {
      "ko": "대변이 묽거나 설사가 잦은 분은 구기자의 서늘한 성질로 인해 설사가 심해질 수 있습니다.",
      "en": "Those with loose stools or frequent diarrhea should exercise caution, as the cooling nature of goji berries may worsen diarrhea.",
      "ja": "便が緩かったり下痢がちの方は、クコの実の涼性によって下痢が悪化することがあります。",
      "ar": "يجب على الأشخاص الذين يعانون من براز رخو أو إسهال متكرر توخي الحذر، لأن طبيعة تبريد توت غوجي قد تؤدي إلى تفاقم الإسهال."
    },
    "토종 지리산": {
      "ko": "토종 지리산",
      "en": "Native Jirisan",
      "ja": "在来種智異山",
      "ar": "جيريسان الأصلي"
    },
    "100g / 건조": {
      "ko": "100g / 건조",
      "en": "100g / dried",
      "ja": "100g / 乾燥",
      "ar": "100 جم / مجفف"
    },
    "보성 야생 녹차 (우전 등급)": {
      "ko": "보성 야생 녹차 (우전 등급)",
      "en": "Boseong Wild Green Tea — Ujeon Grade",
      "ja": "宝城野生緑茶 (雨前等級)",
      "ar": "شاي بوسونغ الأخضر البري - درجة أوجيون"
    },
    "전남 보성 첫물 찻잎 4월 우전 등급. 카테킨과 테아닌 함량 최고치 — 항산화와 정신 집중력 강화에 최적.": {
      "ko": "전남 보성 첫물 찻잎 4월 우전 등급. 카테킨과 테아닌 함량 최고치 — 항산화와 정신 집중력 강화에 최적.",
      "en": "First-flush Ujeon grade green tea leaves harvested in April from Boseong, Jeollanam-do. Contains maximum levels of catechins and L-theanine — optimal for antioxidant support and cognitive focus.",
      "ja": "全羅南道・宝城（ポソン）で4月に収穫された一番茶の雨前（ウジョン）等級緑茶。カテキンとテアニンの含有量が最大で、抗酸化と精神集中の強化に最適です。",
      "ar": "أوراق الشاي الأخضر من الدرجة الأولى التي يتم حصادها في أبريل من بوسونغ، جولا نام-دو. يحتوي على مستويات قصوى من الكاتيكين وإل-ثيانين - الأمثل لدعم مضادات الأكسدة والتركيز المعرفي."
    },
    "70~80℃로 식힌 따뜻한 물 150ml에 녹찻잎 2g을 넣고 1분 30초간 우려내어 음용합니다.": {
      "ko": "70~80℃로 식힌 따뜻한 물 150ml에 녹찻잎 2g을 넣고 1분 30초간 우려내어 음용합니다.",
      "en": "Steep 2g of green tea leaves in 150ml of warm water cooled to 70–80°C for 1 minute and 30 seconds before drinking.",
      "ja": "70〜80℃に冷ました温水150mlに緑茶葉2gを入れ、1分30秒間抽出してお召し上がりください。",
      "ar": "ينقع 2 جم من أوراق الشاي الأخضر في 150 مل من الماء الدافئ المبرد إلى 70-80 درجة مئوية لمدة دقيقة و30 ثانية قبل الشرب."
    },
    "카페인 성분이 들어있으므로 불면증이 있거나 카페인에 예민한 분은 늦은 저녁 음용을 피하십시오.": {
      "ko": "카페인 성분이 들어있으므로 불면증이 있거나 카페인에 예민한 분은 늦은 저녁 음용을 피하십시오.",
      "en": "Contains caffeine. Those with insomnia or caffeine sensitivity should avoid consumption in the late evening.",
      "ja": "カフェインが含まれているため、不眠症のある方やカフェインに敏感な方は、遅い夜間の飲用をお控えください。",
      "ar": "يحتوي على الكافيين. يجب على الأشخاص الذين يعانون من الأرق أو حساسية الكافيين تجنب الاستهلاك في وقت متأخر من المساء."
    },
    "우전 1등급": {
      "ko": "우전 1등급",
      "en": "First Grade Ujeon",
      "ja": "雨前1等級",
      "ar": "أوجيون من الدرجة الأولى"
    },
    "50g / 금속 캔": {
      "ko": "50g / 금속 캔",
      "en": "50g / tin can",
      "ja": "50g / 金属缶",
      "ar": "50 جم / علبة معدنية"
    },
    "황차 (黃茶) — 구증구포 제다": {
      "ko": "황차 (黃茶) — 구증구포 제다",
      "en": "Korean Yellow Tea — 9x Steamed",
      "ja": "黄茶 (ファンチャ) — 九蒸九曝製茶",
      "ar": "الشاي الأصفر الكوري - مبخر 9 مرات"
    },
    "전통 구증구포 방식으로 만든 황차. 소화 촉진과 혈당 조절, 위장 안정에 탁월.": {
      "ko": "전통 구증구포 방식으로 만든 황차. 소화 촉진과 혈당 조절, 위장 안정에 탁월.",
      "en": "Yellow tea crafted using the traditional nine-steaming, nine-drying (Gujeung-gupo) process. Excellent for promoting digestion, regulating blood sugar, and soothing the stomach.",
      "ja": "伝統的な九蒸九曝（九回蒸して九回干す）製法で作られた黄茶。消化促進、血糖調整、胃の安定に優れています。",
      "ar": "شاي أصفر مصنوع باستخدام عملية التبخير والتجفيف التقليدية تسع مرات. ممتاز لتعزيز الهضم، وتنظيم السكر في الدم، وتهدئة المعدة."
    },
    "85~90℃의 뜨거운 물 200ml에 황차 2.5g을 넣고 2분간 우려 마십니다. 여러 번 재우림이 가능합니다.": {
      "ko": "85~90℃의 뜨거운 물 200ml에 황차 2.5g을 넣고 2분간 우려 마십니다. 여러 번 재우림이 가능합니다.",
      "en": "Steep 2.5g of yellow tea in 200ml of hot water at 85–90°C for 2 minutes. Can be re-steeped multiple times.",
      "ja": "85〜90℃のお湯200mlに黄茶2.5gを入れ、2分間抽出してお召し上がりください。複数回の再抽出が可能です。",
      "ar": "ينقع 2.5 جم من الشاي الأصفر في 200 مل من الماء الساخن عند 85-90 درجة مئوية لمدة دقيقتين. يمكن إعادة نقعه عدة مرات."
    },
    "공복에 너무 많이 마시면 속이 쓰릴 수 있으니 식후 30분에 마시는 것을 권장합니다.": {
      "ko": "공복에 너무 많이 마시면 속이 쓰릴 수 있으니 식후 30분에 마시는 것을 권장합니다.",
      "en": "Drinking too much on an empty stomach may cause heartburn; drinking 30 minutes after a meal is recommended.",
      "ja": "空腹時に飲みすぎると胃もたれの原因になることがありますので、食後30分に飲むことをお勧めします。",
      "ar": "قد يؤدي شرب الكثير على معدة فارغة إلى حرقة المعدة؛ يُنصح بالشرب بعد 30 دقيقة من تناول الوجبة."
    },
    "구증구포": {
      "ko": "구증구포",
      "en": "9x Steamed & Dried",
      "ja": "九蒸九曝",
      "ar": "تبخير وتجفيف 9 مرات"
    },
    "50g / 전통 포장": {
      "ko": "50g / 전통 포장",
      "en": "50g / traditional wrap",
      "ja": "50g / 伝統包装",
      "ar": "50 جم / غلاف تقليدي"
    },
    "한라산 야생 민들레 꽃차": {
      "ko": "한라산 야생 민들레 꽃차",
      "en": "Hallasan Wild Dandelion Flower Tea",
      "ja": "漢拏山野生タンポポ花茶",
      "ar": "شاي زهرة الهندباء البرية جبل هالاسان"
    },
    "청정 한라산 야생 민들레를 손으로 채취하여 저온 건조한 꽃차. 간열 해소, 이뇨 작용, 소화 개선.": {
      "ko": "청정 한라산 야생 민들레를 손으로 채취하여 저온 건조한 꽃차. 간열 해소, 이뇨 작용, 소화 개선.",
      "en": "Flower tea made by hand-picking wild dandelions from pristine Mount Halla and drying them at low temperatures. Clears liver heat, acts as a diuretic, and improves digestion.",
      "ja": "清浄な漢拏山（ハルラサン）の野生のタンポポを手作業で採取し、低温乾燥させた花茶。肝臓の熱の解消、利尿作用、消化改善に優れています。",
      "ar": "شاي زهور مصنوع من قطف الهندباء البرية يدويًا من جبل هالا النقي وتجفيفها في درجات حرارة منخفضة. يزيل حرارة الكبد، ويعمل كمدر للبول، ويحسن الهضم."
    },
    "100℃의 끓는 물 150ml에 건조 꽃송이 2~3개를 띄우고 꽃이 활짝 피어날 때(3분)까지 우려 마십니다.": {
      "ko": "100℃의 끓는 물 150ml에 건조 꽃송이 2~3개를 띄우고 꽃이 활짝 피어날 때(3분)까지 우려 마십니다.",
      "en": "Place 2-3 dried flower buds in 150ml of boiling water at 100°C. Steep for 3 minutes until the flowers fully bloom.",
      "ja": "100℃の沸騰したお湯150mlに乾燥花2〜3個を浮かべ、花がきれいに開くまで（3分間）抽出してお召し上がりください。",
      "ar": "ضع 2-3 براعم زهور مجففة في 150 مل من الماء المغلي عند 100 درجة مئوية. انقعها لمدة 3 دقائق حتى تتفتح الزهور تمامًا."
    },
    "차가운 성질이 강하므로 아랫배가 차거나 위장이 얇아 설사가 잦은 분은 장복을 피하십시오.": {
      "ko": "차가운 성질이 강하므로 아랫배가 차거나 위장이 얇아 설사가 잦은 분은 장복을 피하십시오.",
      "en": "Highly cooling in nature. Those with a cold lower abdomen or weak stomach prone to diarrhea should avoid long-term consumption.",
      "ja": "涼性が強いため、下腹部が冷えていたり、胃腸が弱く下痢がちな方は長期の飲用をお控えください。",
      "ar": "له طبيعة تبريد عالية. يجب على الأشخاص الذين يعانون من برودة أسفل البطن أو معدة ضعيفة معرضة للإسهال تجنب الاستهلاك طويل الأمد."
    },
    "한라산 야생": {
      "ko": "한라산 야생",
      "en": "Wild Hallasan",
      "ja": "漢拏山野生",
      "ar": "هالاسان البري"
    },
    "30g / 한지 포장": {
      "ko": "30g / 한지 포장",
      "en": "30g / Hanji paper wrap",
      "ja": "30g / 韓紙包装",
      "ar": "30 جم / غلاف ورقي هانجي"
    },
    "제주 한방 쑥차 (삼년쑥)": {
      "ko": "제주 한방 쑥차 (삼년쑥)",
      "en": "Jeju 3-Year Aged Mugwort Tea",
      "ja": "済州漢方よもぎ茶 (三年よもぎ)",
      "ar": "شاي الشيح الطبي الكوري لثلاث سنوات جيجو"
    },
    "3년간 저장 숙성한 제주 쑥으로 만든 따뜻한 쑥차. 냉체질 개선, 위장 온열, 여성 생리 불순 완화.": {
      "ko": "3년간 저장 숙성한 제주 쑥으로 만든 따뜻한 쑥차. 냉체질 개선, 위장 온열, 여성 생리 불순 완화.",
      "en": "A warming tea crafted from Jeju mugwort aged for 3 years. Improves cold constitutions, warms the stomach, and helps alleviate female menstrual irregularities.",
      "ja": "3年間貯蔵・熟成させた済州（チェジュ）よもぎで作られた温かいよもぎ茶。冷え性の改善、胃腸の温熱、女性の月経不順の緩和に役立ちます。",
      "ar": "شاي دافئ مصنوع من شيح جيجو المعتق لمدة 3 سنوات. يحسن الدستور البارد، ويدفئ المعدة، ويساعد على تخفيف الاضطرابات الدورية لدى النساء."
    },
    "90℃ 온수 200ml에 건조 쑥잎 2g을 넣고 2분간 우려냅니다. 은은한 쑥 향과 쌉싸름한 맛이 특징입니다.": {
      "ko": "90℃ 온수 200ml에 건조 쑥잎 2g을 넣고 2분간 우려냅니다. 은은한 쑥 향과 쌉싸름한 맛이 특징입니다.",
      "en": "Steep 2g of dried mugwort leaves in 200ml of hot water at 90°C for 2 minutes. Characterized by a subtle mugwort aroma and a slightly bitter taste.",
      "ja": "90℃のお湯200mlに乾燥よもぎ葉2gを入れ、2分間抽出します。ほのかなよもぎの香りと心地よい苦みが特徴です。",
      "ar": "ينقع 2 جم من أوراق الشيح المجففة في 200 مل من الماء الساخن عند 90 درجة مئوية لمدة دقيقتين. يتميز برائحة الشيح اللطيفة وطعم مر قليلاً."
    },
    "체내에 열이 가득 차 마른기침을 하거나 얼굴 홍조가 심한 분은 주의하여 음용하십시오.": {
      "ko": "체내에 열이 가득 차 마른기침을 하거나 얼굴 홍조가 심한 분은 주의하여 음용하십시오.",
      "en": "Those with excess internal body heat, dry coughs, or severe facial flushing should consume with caution.",
      "ja": "体内に熱がこもって乾いた咳が出たり、顔のほてりが酷い方はご注意してお召し上がりください。",
      "ar": "يجب على الأشخاص الذين يعانون من حرارة داخلية زائدة في الجسم، أو سعال جاف، أو احمرار شديد في الوجه الاستهلاك بحذر."
    },
    "3년 숙성": {
      "ko": "3년 숙성",
      "en": "3-Year Aged",
      "ja": "3年熟成",
      "ar": "معتق 3 سنوات"
    },
    "약선 조식 영양 죽 세트 (5종)": {
      "ko": "약선 조식 영양 죽 세트 (5종)",
      "en": "Medicinal Morning Porridge Set (5 Types)",
      "ja": "薬膳朝食栄養粥セット (5種)",
      "ar": "مجموعة ثريد الصباح الطبية (5 أنواع)"
    },
    "흑임자죽, 잣죽, 호박죽, 단호박죽, 팥죽 — 아침을 대신하는 프리미엄 약선 죽 5종 세트.": {
      "ko": "흑임자죽, 잣죽, 호박죽, 단호박죽, 팥죽 — 아침을 대신하는 프리미엄 약선 죽 5종 세트.",
      "en": "Black sesame, pine nut, pumpkin, sweet pumpkin, and red bean — a premium 5-piece set of medicinal herbal porridges to replace breakfast.",
      "ja": "黒ごま粥、松の実粥、かぼちゃ粥、甘かぼちゃ粥、小豆粥 — 朝食の代わりになるプレミアム薬膳粥5種セット。",
      "ar": "السمسم الأسود، صنوبر، اليقطين، اليقطين الحلو، والفاصوليا الحمراء - مجموعة فاخرة من 5 قطع من الثريد العشبي الطبي ليحل محل الإفطار."
    },
    "팩 그대로 끓는 물에 5분간 중탕하거나, 전자레인지 용기에 덜어 2분간 데워 따뜻하게 섭취하십시오.": {
      "ko": "팩 그대로 끓는 물에 5분간 중탕하거나, 전자레인지 용기에 덜어 2분간 데워 따뜻하게 섭취하십시오.",
      "en": "Boil the pack directly in water for 5 minutes, or transfer to a microwave-safe container and heat for 2 minutes to serve warm.",
      "ja": "パックのまま沸騰したお湯で5分間湯煎するか、電子レンジ対応容器に移して2分間温めて温かい状態でお召し上がりください。",
      "ar": "اغل العبوة مباشرة في الماء لمدة 5 دقائق، أو انقلها إلى وعاء آمن للميكروويف وسخنها لمدة دقيقتين لتقديمها دافئة."
    },
    "전자레인지 조리 시 봉지째 직접 가열하지 마시고 반드시 전용 용기에 덜어 조리하십시오.": {
      "ko": "전자레인지 조리 시 봉지째 직접 가열하지 마시고 반드시 전용 용기에 덜어 조리하십시오.",
      "en": "When microwaving, do not heat the pouch directly; always transfer the contents to a microwave-safe container.",
      "ja": "電子レンジ調理の際、袋のまま直接加熱せず、必ず電子レンジ対応容器に移して調理してください。",
      "ar": "عند استخدام الميكروويف، لا تسخن الكيس مباشرة؛ قم دائمًا بنقل المحتويات إلى وعاء آمن للميكروويف."
    },
